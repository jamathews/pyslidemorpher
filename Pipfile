[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
opencv-python = "*"
numpy = "*"
imageio = {extras = ["ffmpeg"], version = "*"}
torch = "*"
torchvision = "*"
pygame = "*"
flask = "*"

[dev-packages]
pytest = "*"
pytest-cov = "*"
coverage = "*"

[scripts]
test = "pytest -q"
test-cov = "pytest -q --cov=pyslidemorpher --cov-report=term-missing --cov-fail-under=23"

[requires]
python_version = "3.13"
python_full_version = "3.13.0"
